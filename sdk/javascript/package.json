{
  "name": "w2a-client",
  "version": "0.1.0",
  "description": "Web2Agent Protocol SDK — discover and interact with W2A-enabled websites",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run"
  },
  "keywords": [
    "w2a",
    "web2agent",
    "ai-agents",
    "mcp",
    "a2a",
    "protocol",
    "llm",
    "langchain",
    "typescript"
  ],
  "author": "W2A Protocol",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nijjwol23/w2a"
  },
  "homepage": "https://w2a-protocol.org",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
